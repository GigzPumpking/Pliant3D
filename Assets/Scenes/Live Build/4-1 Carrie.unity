      propertyPath: dialogueLines.Array.data[0]
      value: Welcome to my desk! Things move a little quicker over here so keep an
        eye out for deadlines!
      objectReference: {fileID: 0}
    - target: {fileID: 3493604527745461607, guid: 89b2ae7bccf9f426999e81c797e9ff4e,
